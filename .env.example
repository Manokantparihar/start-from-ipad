# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_very_secret_jwt_key_here

# ─── Email / SMTP (for notification emails) ───────────────────────────────────
# Set these to enable transactional email delivery.
# If left blank, email notifications are silently skipped (in-app still works).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# For Gmail, use an App Password (not your main account password).
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_smtp_password_or_app_password
# "From" header – customize as needed
SMTP_FROM="RPSC/REET Prep <no-reply@example.com>"

# ─── Site ─────────────────────────────────────────────────────────────────────
SITE_NAME=RPSC/REET Prep

# ─── Contact form forwarding ──────────────────────────────────────────────────
CONTACT_TARGET_EMAIL=you@example.com

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5500
NODE_ENV=development

# ─── Rate Limits ──────────────────────────────────────────────────────────────
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX_REQUESTS=25
# CONTACT_RATE_LIMIT_WINDOW_MS=900000
# CONTACT_RATE_LIMIT_MAX_REQUESTS=5
# IMPORT_RATE_LIMIT_WINDOW_MS=900000
# IMPORT_RATE_LIMIT_MAX_REQUESTS=20
# ADMIN_RATE_LIMIT_WINDOW_MS=60000
# ADMIN_RATE_LIMIT_MAX_REQUESTS=120
